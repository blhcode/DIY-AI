# DIY AI — Ollama configuration
# Copy to diy.env and edit values, then run: bash start.sh

# Use /v1 at the end (NOT /api/chat)
OLLAMA_BASE_URL=
# Run `ollama list` on your Ollama machine to see the exact name (often includes :8b tag)
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=120

# Country preset: AU, US, or UK (sets default stores, search region, and currency)
DEFAULT_COUNTRY=

# Override stores (leave empty to use country defaults)
# AU defaults: Bunnings, Mitre 10, Amazon Australia, Total Tools, Home Timber & Hardware
AVAILABLE_STORES=

# Optional city/state — improves local store search (e.g. Sydney, Melbourne)
DEFAULT_LOCATION=

DIY_PORT=
